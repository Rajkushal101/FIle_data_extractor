APP_ENV=development
MAX_FILE_SIZE=52428800
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOW_ORIGIN_REGEX=https://.*\.vercel\.app

# AI Providers
GROQ_API_KEY=
GEMINI_API_KEY=
NVIDIA_ENABLED=false
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL_VISION=meta/llama-3.2-90b-vision-instruct
NVIDIA_MODEL_TEXT=meta/llama-3.1-70b-instruct
NVIDIA_MODEL_ENHANCEMENT=meta/llama-3.1-405b-instruct
PRIMARY_AI_PROVIDER=nvidia
STRICT_AI_PROVIDER=true
